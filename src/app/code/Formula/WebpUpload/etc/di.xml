<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Magento\Catalog\Model\Product\Gallery\Processor"
                type="Formula\WebpUpload\Model\Product\Gallery\Processor"/>

    <type name="Magento\Catalog\Controller\Adminhtml\Product\Gallery\Upload">
        <plugin name="formula_webp_allow_upload" type="Formula\WebpUpload\Plugin\AllowWebpUpload"/>
    </type>

    <type name="Magento\Framework\Image\Adapter\Gd2">
        <plugin name="formula_webp_gd2_support" type="Formula\WebpUpload\Plugin\Gd2WebpSupport"/>
    </type>

    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="formulaConvertImages" xsi:type="object">Formula\WebpUpload\Console\Command\ConvertImages</item>
            </argument>
        </arguments>
    </type>

    <type name="Formula\Brand\Model\ImageUploader">
        <plugin name="formula_webp_brand_upload" type="Formula\WebpUpload\Plugin\BrandImageUploaderPlugin"/>
    </type>

    <type name="Formula\HomeContent\Model\ImageUploader">
        <plugin name="formula_webp_homecontent_upload" type="Formula\WebpUpload\Plugin\HomeContentImageUploaderPlugin"/>
    </type>

    <type name="Formula\CategoryBanners\Model\BannerImageUploader">
        <plugin name="formula_webp_categorybanner_upload" type="Formula\WebpUpload\Plugin\CategoryBannersUploaderPlugin"/>
    </type>

    <type name="Formula\CountryFormulaBanners\Model\BannerImageUploader">
        <plugin name="formula_webp_countryformulabanner_upload" type="Formula\WebpUpload\Plugin\CountryFormulaBannersUploaderPlugin"/>
    </type>
</config>
