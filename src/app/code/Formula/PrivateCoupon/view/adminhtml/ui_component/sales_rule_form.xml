<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <fieldset name="rule_information">
        <field name="is_storefront_hidden" sortOrder="35">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="formElement" xsi:type="string">checkbox</item>
                    <item name="componentType" xsi:type="string">field</item>
                    <item name="source" xsi:type="string">sales_rule</item>
                    <item name="label" xsi:type="string" translate="true">Hide from storefront coupon listing</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="dataType" xsi:type="string">boolean</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="false" xsi:type="number">0</item>
                        <item name="true" xsi:type="number">1</item>
                    </item>
                    <item name="default" xsi:type="number">0</item>
                    <item name="dataScope" xsi:type="string">is_storefront_hidden</item>
                    <item name="tooltip" xsi:type="array">
                        <item name="description" xsi:type="string" translate="true">When enabled, this coupon will not appear in the website coupon popup. Users can still apply it manually at checkout.</item>
                    </item>
                </item>
            </argument>
        </field>
    </fieldset>
</form>
